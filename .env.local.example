# ─── Supabase / PostgreSQL ────────────────────────────────────────────────────
# Vai su supabase.com → progetto → Settings → Database → Connection string
# Usa la stringa "Transaction" (porta 6543) per DATABASE_URL (Prisma pooled)
# Usa la stringa "Session" (porta 5432) per DIRECT_URL (migrazioni)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# ─── NextAuth v5 ─────────────────────────────────────────────────────────────
# Genera con: openssl rand -base64 32
AUTH_SECRET="sostituisci-con-segreto-random-32-caratteri"

# URL del sito (in produzione sarà il dominio Vercel)
NEXTAUTH_URL="http://localhost:3000"

# ─── Resend (email transazionale) ────────────────────────────────────────────
# Vai su resend.com → API Keys → crea una chiave
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
# In produzione: usa un dominio verificato, es. "Forno Irma <noreply@tuodominio.it>"
# In sviluppo/test: usa "onboarding@resend.dev" (invia solo all'email del tuo account Resend)
RESEND_FROM="Forno Irma <onboarding@resend.dev>"

# ─── URL pubblico del sito (per link nelle email) ─────────────────────────────
NEXT_PUBLIC_SITE_URL="https://forno-irma.vercel.app"
