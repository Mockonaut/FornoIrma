generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth (NextAuth v5 / @auth/prisma-adapter) ───────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  phone         String?
  image         String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  reservations  Reservation[]
  notifications Notification[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Catalogo ─────────────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  sortOrder   Int      @default(0)
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())

  products Product[]
}

model Product {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  shortDescription String?
  description      String?  @db.Text
  categoryId       String
  isSeasonal       Boolean  @default(false)
  isSpecial        Boolean  @default(false)
  isVisible        Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  category         Category       @relation(fields: [categoryId], references: [id])
  images           ProductImage[]
  reservationItems ReservationItem[]
}

model ProductImage {
  id        String @id @default(cuid())
  productId String
  url       String
  altText   String?
  sortOrder Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ─── Prenotazioni ─────────────────────────────────────────────────────────────

model PickupSlot {
  id        String   @id @default(cuid())
  label     String
  startTime String
  endTime   String
  maxOrders Int      @default(20)
  isActive  Boolean  @default(true)

  reservations Reservation[]
}

model Reservation {
  id           String            @id @default(cuid())
  code         String            @unique
  userId       String
  pickupDate   DateTime
  pickupSlotId String
  status       ReservationStatus @default(PENDING)
  notes        String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  pickupSlot PickupSlot  @relation(fields: [pickupSlotId], references: [id])
  items      ReservationItem[]
}

model ReservationItem {
  id            String @id @default(cuid())
  reservationId String
  productId     String
  productName   String
  quantity      Int

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id])
}

// ─── Pane del giorno ──────────────────────────────────────────────────────────

model BreadType {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  schedules DailySchedule[]
}

model DailySchedule {
  id          String    @id @default(cuid())
  breadTypeId String
  // Exactly one of the two must be set:
  date        DateTime? @db.Date   // specific date (overrides recurring)
  dayOfWeek   Int?                 // ISO: 1=Mon … 7=Sun (recurring)
  notes       String?
  createdAt   DateTime  @default(now())

  breadType BreadType @relation(fields: [breadTypeId], references: [id], onDelete: Cascade)

  @@unique([date])
  @@unique([dayOfWeek])
}

// ─── Contenuti del sito ────────────────────────────────────────────────────────

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  title     String?
  body      String?  @db.Text
  updatedAt DateTime @updatedAt
}

model BusinessSettings {
  id                 String   @id @default(cuid())
  address            String?
  phone              String?
  email              String?
  instagramUrl       String?
  mapEmbedUrl        String?
  pickupInstructions String?
  openingHours       Json?
  updatedAt          DateTime @updatedAt
}

// ─── Chiusure straordinarie ───────────────────────────────────────────────────

model ClosureDate {
  id        String   @id @default(cuid())
  date      DateTime @db.Date @unique
  reason    String?
  createdAt DateTime @default(now())
}

// ─── Notifiche ────────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  linkUrl   String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  READY
  COMPLETED
  CANCELLED
}

enum NotificationType {
  NEW_RESERVATION      // per admin: nuova prenotazione ricevuta
  RESERVATION_CONFIRMED // per utente: prenotazione confermata
  RESERVATION_READY     // per utente: ordine pronto per il ritiro
  RESERVATION_CANCELLED // per utente: prenotazione annullata
}
